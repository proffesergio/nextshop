{
  "name": "nextshop",
  "version": "0.1.0",
  "private": true,
  "description": "Config-driven, multi-client grocery eCommerce PWA template (Medusa + Next.js)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "new:client": "tsx scripts/new-client.ts",
    "audit": "pnpm audit --prod"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}

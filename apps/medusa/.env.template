# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/grocery_medusa

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Change these to strong, unique random strings in every environment.
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for each context.
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# When set, Medusa uses Redis for the event bus and workflow engine.
# Omit entirely to fall back to in-memory implementations (dev only).
# REDIS_URL=redis://localhost:6379

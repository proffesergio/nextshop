{
  "name": "@nextshop/db",
  "version": "0.1.0",
  "type": "module",
  "description": "NextShop custom commerce backend — repository (in-memory + Neon/Drizzle), shared & published.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/proffesergio/nextshop.git",
    "directory": "packages/db"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "files": ["src", "drizzle.config.ts"],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@nextshop/commerce-core": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@nextshop/eslint-config": "workspace:*",
    "@nextshop/tsconfig": "workspace:*",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
